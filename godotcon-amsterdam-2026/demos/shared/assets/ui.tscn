[gd_scene format=3 uid="uid://dxw74vrvvm3ov"]

[sub_resource type="GDScript" id="GDScript_7ren2"]
script/source = "extends Label

func _physics_process(_dt: float) -> void:
	text = _get_multiplayer_label()

func _get_multiplayer_label() -> String:
	if not multiplayer.has_multiplayer_peer():
		return \"disconnected\"

	if multiplayer.multiplayer_peer.get_connection_status() != MultiplayerPeer.ConnectionStatus.CONNECTION_CONNECTED:
		return \"disconnected\"

	if multiplayer.is_server():
		return \"server\"

	return \"client #%d\" % multiplayer.get_unique_id()
"

[sub_resource type="GDScript" id="GDScript_8w8lg"]
script/source = "extends Label

func _physics_process(_dt: float) -> void:
	text = \"FPS: ~%d\" % [Engine.get_frames_per_second()]
"

